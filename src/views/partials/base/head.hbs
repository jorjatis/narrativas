  {{!-- NOTE: Js de voonto --}}
  <link rel="preload" as="script" href="//static.vocstatic.com/voonto2/latest/voonto.js">
  
  <title>{{metadata.infoContainer.title}}</title>

  {{!-- NOTE: Metas --}}
  <meta name="title" content="{{metadata.infoContainer.title}}"/>
  <meta name="description" content="{{metadata.infoContainer.description}}"/>
  <meta property="og:title" content="{{metadata.infoContainer.title}}"/>
  <meta property="og:description" content="{{metadata.infoContainer.description}}"/>
  <meta property="og:type" content="article"/>
  <meta property="og:locale" content="es_ES"/>
  <meta property="og:site_name" content="Diario ABC"/>
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image" content="{{metadata.coverUrl}}"/>
  <meta property="og:image:width" content="1024"/>
  <meta property="og:image:height" content="512"/>
  <meta name="twitter:title" content="{{metadata.coverUrl}}"/>
  <meta name="twitter:description" content="{{metadata.infoContainer.description}}"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:image:src" content="{{metadata.infoContainer.title}}"/>
  <meta name="twitter:image:width" content="1200"/>
  <meta name="twitter:image:height" content="630"/>
  <meta name="twitter:widgets:csp" content="on">

  {{!-- NOTE: Favicons --}}
  {{> ./base/head-favicons }}
</head>
