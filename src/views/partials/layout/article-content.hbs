  <script>
    function scrollControl() {
      const scrollWrappers = document.querySelectorAll('.b-voc-scroll-wrapper');
      scrollWrappers.forEach(wrapper => {
        const sticky = wrapper.querySelector('.b-voc-scroll-sticky');
        const contenido = wrapper.querySelector('.b-voc-scroll-contenido');
        if (sticky && contenido) {
          const idpos1 = sticky.getBoundingClientRect().top;
          const maxWidth = contenido.scrollWidth;
          wrapper.style.height = (maxWidth - window.innerWidth + window.innerHeight) + 'px';
          const scrollPos = wrapper.getBoundingClientRect().top;
          if (idpos1 == 0) {
            contenido.style.left = (scrollPos) + 'px';
          }
        }
      });
      requestAnimationFrame(scrollControl);
    }
    window.requestAnimationFrame(scrollControl);
  </script>
