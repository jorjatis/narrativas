<article class="card">
  <a class="media-container" href="{{url}}" aria-label="Abrir {{title}}">
    <img src="{{image}}" alt="{{title}}" loading="lazy" class="thumbnail">
    <video src="{{video}}" muted loop playsinline aria-hidden="true" class="preview-video"></video>
  </a>
  <div class="card-footer">
    <h3 class="narrativa-titulo">{{title}}</h3>
    <div class="actions">
      <a href="{{actionWebUrl}}" target="_blank" rel="noopener noreferrer" title="Ver web de {{title}}" aria-label="Ver web de {{title}}">
        <i class="fas fa-globe" aria-hidden="true"></i>
      </a>
      <a href="{{actionMockupUrl}}" target="_blank" rel="noopener noreferrer" title="Ver mockup de {{title}}" aria-label="Ver mockup de {{title}}">
        <i class="fas fa-desktop" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</article>
