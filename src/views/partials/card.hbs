<article class="card">
  <a class="card-media" href="{{articleUrl}}" target="_blank" rel="noopener noreferrer" aria-label="Abrir {{title}}">
    <img src="assets/images/covers/{{titleMedia}}{{#if gif}}.gif{{else}}.jpg{{/if}}" alt="{{title}}" loading="lazy" class="card-media-thumbnail">
  </a>
  <div class="card-body">
    <h3 class="card-title">
      <a class="card-title-link" href="{{articleUrl}}" target="_blank" rel="noopener noreferrer">
        {{title}}
      </a>
    </h3>
    <div class="card-actions">
      <a class="card-action card-action--primary" href="{{articleUrl}}" target="_blank" rel="noopener noreferrer" title="Ver narrativa de {{title}} en ABC" aria-label="Ver narrativa de {{title}} en ABC">
        Leer en ABC
      </a>
      <a class="card-action" href="{{netlifyUrl}}" target="_blank" rel="noopener noreferrer" title="Ver narrativa de {{title}} en Netlify" aria-label="Ver narrativa de {{title}} en Netlify">
        Ver Netlify
      </a>
    </div>
  </div>
</article>
