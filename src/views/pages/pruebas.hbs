<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Previsión Crecimiento 2026 - Responsive</title>
  <script src="https://d3js.org/d3.v7.min.js"></script>
  <style>
    body {
      font-family: 'Roboto', sans-serif;
      background-color: #e3e2d3;
      margin: 0;
      padding: 10px;
      display: flex;
      justify-content: center;
    }

    #chart-container {
      width: 100%;
      max-width: 900px;
      background-color: #e3e2d3;
    }

    .domain {
      display: none;
    }

    .tooltip {
      position: absolute;
      background-color: rgba(227, 226, 211, 0.98);
      padding: 10px;
      border: 1px solid #b8b6a3;
      pointer-events: none;
      opacity: 0;
      font-size: 14px;
      box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
      z-index: 100;
    }

    .tick text {
      font-family: 'Roboto', sans-serif;
    }
  </style>
</head>

<body>

  <div id="chart-container"></div>
  <div id="tooltip" class="tooltip"></div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const data = [
        { country: "Mundo*", value: 3.3 },
        { country: "Economías avanzadas*", value: 1.8 },
        { country: "EEUU", value: 2.4 },
        { country: "Eurozona*", value: 1.3 },
        { country: "Alemania", value: 1.1 },
        { country: "Francia", value: 1.0 },
        { country: "Italia", value: 0.7 },
        { country: "España", value: 2.3 },
        { country: "Japón", value: 0.7 },
        { country: "Reino Unido", value: 1.4 },
        { country: "Canadá", value: 1.6 },
        { country: "Emergentes*", value: 4.2 },
        { country: "China", value: 4.5 },
        { country: "India", value: 6.5 },
        { country: "Latinoamérica y Caribe*", value: 2.2 }
      ];

      function drawChart() {
        const containerElement = document.querySelector('#chart-container');
        const screenWidth = containerElement.offsetWidth;

        const isMobile = screenWidth <= 699;

        const margin = {
          top: 100,
          right: 30,
          bottom: 80,
          left: isMobile ? 130 : 220
        };

        const width = screenWidth;
        const height = 650;
        const innerWidth = width - margin.left - margin.right;
        const innerHeight = height - margin.top - margin.bottom;

        const fontSize = isMobile ? "11px" : "15px";

        d3.select("#chart-container").selectAll("*").remove();

        const svg = d3.select("#chart-container")
          .append("svg")
          .attr("width", width)
          .attr("height", height)
          .append("g")
          .attr("transform", `translate(${margin.left},${margin.top})`);

        const x = d3.scaleLinear().domain([0, 7]).range([0, innerWidth]);
        const y = d3.scaleBand()
          .domain(data.map(d => d.country))
          .range([0, innerHeight])
          .padding(0.85);

        svg.append("g")
          .call(d3.axisTop(x).ticks(isMobile ? 4 : 7).tickSize(-innerHeight).tickFormat(d => d + "%"))
          .call(g => g.selectAll(".tick line").attr("stroke", "#b0b0b0").attr("stroke-dasharray", "2,2"))
          .call(g => g.selectAll(".tick text").attr("dy", "-10px").style("font-size", fontSize));

        const yAxis = svg.append("g")
          .call(d3.axisLeft(y).tickSize(0));

        yAxis.selectAll(".tick text")
          .style("font-size", fontSize)
          .style("fill", (d, i) => i % 2 === 0 ? "#777" : "#111")
          .attr("x", isMobile ? -margin.left + 5 : -15) 
          .attr("text-anchor", isMobile ? "start" : "end");

        const tooltip = d3.select("#tooltip");

        svg.selectAll(".bar")
          .data(data)
          .enter()
          .append("rect")
          .attr("y", d => y(d.country))
          .attr("height", y.bandwidth())
          .attr("x", 0)
          .attr("fill", "#5424df")
          .attr("width", 0)
          .on("mouseover", (event, d) => {
            tooltip.style("opacity", 1).html(`
                    <div style="font-style:italic; color:#666; margin-bottom:4px;">${d.country}</div>
                    <div style="font-weight:bold; color:#111;">Crecimiento del PIB: ${d.value}%</div>
                `);
          })
          .on("mousemove", (event) => {
            tooltip.style("left", (event.pageX + 15) + "px")
              .style("top", (event.pageY - 20) + "px");
          })
          .on("mouseleave", () => tooltip.style("opacity", 0))
          .transition().duration(800)
          .attr("width", d => x(d.value));


        svg.append("text")
          .attr("x", isMobile ? -margin.left + 5 : -margin.left + 20)
          .attr("y", -65)
          .style("font-size", isMobile ? "14px" : "18px")
          .style("font-weight", "bold")
          .text("PREVISIÓN DE CRECIMIENTO EN 2026");

        svg.append("text")
          .attr("x", innerWidth)
          .attr("y", innerHeight + 60)
          .attr("text-anchor", "end")
          .style("font-size", "12px")
          .style("font-weight", "bold")
          .text("Fuente: FMI");
      }

      drawChart();
      window.addEventListener('resize', drawChart);
    });
  </script>
</body>

</html>